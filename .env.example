# Copy to .env (kept out of git) for local docker-compose overrides.
# In production on Render, DATABASE_URL is injected automatically — these are unused there.

DB_HOST=db
DB_PORT=5432
DB_NAME=medys_catering
DB_USER=medys
DB_PASS=medys

# Set to 1 to surface PDO error details in JSON responses (dev only).
APP_DEBUG=1
